{
  "name": "@ytmod/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "XDG_CONFIG_HOME=../../.wrangler WRANGLER_LOG=none npx wrangler dev --remote",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.2",
    "@ytmod/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "drizzle-kit": "^0.31.10",
    "fast-check": "^4.6.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vitest": "^4.1.3",
    "wrangler": "^3.60.0"
  }
}
