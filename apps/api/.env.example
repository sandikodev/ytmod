# YouTube Data API v3 key
# Get yours at: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Comma-separated allowed CORS origins
# Example: https://yourusername.github.io,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://yourusername.github.io

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret — generate: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Turso database — get credentials at: https://turso.tech
# Format URL: libsql://your-db-name.turso.io
TURSO_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# ─── Clipper Engine URL ────────────────────────────────────────────────────────
# Base URL of your deployed Clipper Engine (clipper-server Rust binary).
# Change this per environment — no rebuild needed.
#
# ── Local development ──────────────────────────────────────────────────────────
# Run clipper-server locally:
#   PORT=8080 ./target/release/clipper-server
CLIPPER_ENGINE_URL=http://localhost:8080
#
# ── Preview / Staging ─────────────────────────────────────────────────────────
# Expose local port via ngrok (free tier, URL changes on restart):
#   ngrok http 8080
# CLIPPER_ENGINE_URL=https://abc123.ngrok-free.app
#
# Expose via Cloudflare Tunnel (stable URL, free):
#   cloudflared tunnel --url http://localhost:8080
# CLIPPER_ENGINE_URL=https://clipper.your-tunnel.cfargotunnel.com
#
# ── Production — Self-hosted ───────────────────────────────────────────────────
# Docker + Nginx reverse proxy:
# CLIPPER_ENGINE_URL=https://clipper-api.yourdomain.com
#
# Docker + Traefik:
# CLIPPER_ENGINE_URL=https://clipper.yourdomain.com
#
# Docker + Apache ProxyPass:
# CLIPPER_ENGINE_URL=https://yourdomain.com/clipper
#
# Docker network (internal, if ytmod-api also runs in same Docker network):
# CLIPPER_ENGINE_URL=http://clipper-service:8080
#
# ── Production — Serverless / PaaS ────────────────────────────────────────────
# Vercel (if wrapped in serverless function):
# CLIPPER_ENGINE_URL=https://your-app.vercel.app/api/clipper
#
# Cloudflare Workers (separate worker):
# CLIPPER_ENGINE_URL=https://clipper.your-subdomain.workers.dev
#
# Generic serverless with versioned path:
# CLIPPER_ENGINE_URL=https://api.yourdomain.com/v1/clipper
