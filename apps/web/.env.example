# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL ytmod API (Cloudflare Workers).
# Development: wrangler dev → localhost:8787
VITE_API_URL=http://localhost:8787

# Preview (deployed worker):
# VITE_API_URL=https://ytmod-api.your-subdomain.workers.dev

# Production:
# VITE_API_URL=https://ytmod-api.your-subdomain.workers.dev

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Mekanisme auth: token-based, disimpan di localStorage key 'ytmod_token'.
# Token diisi manual via halaman /login — tidak ada registrasi otomatis.
# Development: isi token sembarang untuk bypass auth lokal
# Production: gunakan token yang di-generate dari backend (JWT atau opaque token)
