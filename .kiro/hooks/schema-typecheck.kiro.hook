{
  "enabled": true,
  "name": "Typecheck on Schema Change",
  "description": "Jalankan pnpm typecheck otomatis setiap kali packages/shared/src/index.ts diedit, memastikan schema valid sebelum lanjut ke test/impl",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "packages/shared/src/*.ts"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pnpm typecheck",
    "timeout": 60
  }
}